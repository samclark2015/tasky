{
  "$schema": "../gen/schemas/macOS-schema.json",
  "identifier": "default",
  "description": "Default Tasky capabilities",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "sql:default",
    "sql:allow-execute",
    "notification:default",
    "updater:default",
    "process:allow-restart"
  ]
}