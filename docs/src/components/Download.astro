<section class="py-20 sm:py-28 bg-gradient-to-b from-white to-brand-50/50">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900">
      Ready to get started?
    </h2>
    <p class="mt-4 text-lg text-gray-500 max-w-xl mx-auto">
      Download Tasky for macOS and start managing your tasks with the tools you already use.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="https://github.com/samclark2015/tasky/releases"
        class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl bg-brand-500 text-white font-semibold text-base shadow-lg shadow-brand-500/25 hover:bg-brand-600 hover:shadow-brand-600/25 transition-all duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
          <polyline points="7 10 12 15 17 10" />
          <line x1="12" y1="15" x2="12" y2="3" />
        </svg>
        Download Latest Release
      </a>
    </div>

    <p class="mt-4 text-sm text-gray-400">
      Free and open source &middot; macOS (Apple Silicon)
    </p>
  </div>
</section>
