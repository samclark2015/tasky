---
const base = import.meta.env.BASE_URL;
---

<section class="relative overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-50 via-white to-blue-50"></div>
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-100/40 rounded-full blur-3xl -translate-y-1/2 translate-x-1/4"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-indigo-100/30 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>

  <div class="relative max-w-5xl mx-auto px-6 pt-24 pb-20 sm:pt-32 sm:pb-28">
    <div class="flex flex-col items-center text-center">
      <!-- Logo -->
      <img
        src={`${base}logo.svg`}
        alt="Tasky logo"
        class="w-72 sm:w-96 h-auto mb-8"
      />

      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-900 max-w-3xl leading-[1.1]">
        Task management that
        <span class="text-brand-500">syncs with your tools</span>
      </h1>

      <!-- Subheadline -->
      <p class="mt-6 text-lg sm:text-xl text-gray-600 max-w-2xl leading-relaxed">
        A native desktop app for managing tasks with CalDAV and GitHub integration.
        Fast, private, and built to stay out of your way.
      </p>

      <!-- CTA buttons -->
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a
          href="https://github.com/samclark2015/tasky/releases"
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl bg-brand-500 text-white font-semibold text-base shadow-lg shadow-brand-500/25 hover:bg-brand-600 hover:shadow-brand-600/25 transition-all duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          Download for macOS
        </a>
        <a
          href="https://github.com/samclark2015/tasky"
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl bg-white text-gray-700 font-semibold text-base border border-gray-200 hover:border-gray-300 hover:bg-gray-50 transition-all duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <!-- Platform note -->
      <p class="mt-6 text-sm text-gray-400">
        macOS (Apple Silicon) &middot; More platforms coming soon
      </p>
    </div>
  </div>
</section>
