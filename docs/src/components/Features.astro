---
const features = [
  {
    title: 'CalDAV Sync',
    description: 'Sync tasks with Nextcloud, iCloud, Fastmail, or any CalDAV server. Your data stays yours.',
    icon: 'sync',
  },
  {
    title: 'GitHub Issues',
    description: 'Pull in GitHub issues as tasks. Repositories become task lists, keeping code and planning together.',
    icon: 'github',
  },
  {
    title: 'Calendar View',
    description: 'See tasks and calendar events in day, week, or month views. Drag to reschedule.',
    icon: 'calendar',
  },
  {
    title: 'Smart Views',
    description: 'Today, Inbox, and Planner views surface what matters. Focus on the work, not the system.',
    icon: 'views',
  },
  {
    title: 'Subtasks & Recurrence',
    description: 'Break work down with nested subtasks. Set tasks to repeat daily, weekly, monthly, or custom.',
    icon: 'subtasks',
  },
  {
    title: 'Native & Fast',
    description: 'Built with Tauri and Rust. Launches instantly, uses minimal resources, runs offline.',
    icon: 'native',
  },
];

const iconPaths: Record<string, string> = {
  sync: '<path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/>',
  github: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4M9 18c-4.51 2-5-2-7-2"/>',
  calendar: '<rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>',
  views: '<rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/>',
  subtasks: '<path d="M12 3v12M3 9h6v6H3zM15 9h6v6h-6zM6 15v3h12v-3"/>',
  native: '<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/>',
};
---

<section class="py-20 sm:py-28 bg-white">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900">
        Everything you need, nothing you don't
      </h2>
      <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">
        Tasky is a focused task manager that integrates with the services you already use.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="group relative p-6 rounded-2xl border border-gray-100 bg-gray-50/50 hover:bg-white hover:border-brand-100 hover:shadow-lg hover:shadow-brand-500/5 transition-all duration-300">
          <div class="w-10 h-10 rounded-lg bg-brand-500/10 flex items-center justify-center mb-4 group-hover:bg-brand-500/15 transition-colors">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 text-brand-500"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={iconPaths[feature.icon]}
            />
          </div>
          <h3 class="text-base font-semibold text-gray-900 mb-2">
            {feature.title}
          </h3>
          <p class="text-sm text-gray-500 leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
