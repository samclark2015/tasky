---
const base = import.meta.env.BASE_URL;

const docLinks = [
  { label: 'Getting Started', slug: 'getting-started' },
  { label: 'Task Management', slug: 'task-management' },
  { label: 'Views', slug: 'views' },
  { label: 'Sync', slug: 'sync' },
  { label: 'Keyboard Shortcuts', slug: 'keyboard-shortcuts' },
  { label: 'Settings', slug: 'settings' },
];
---

<footer class="py-12 border-t border-gray-100 bg-white">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-8 mb-10">

      <!-- Brand -->
      <div class="col-span-2 sm:col-span-1">
        <p class="text-sm font-semibold text-gray-900 mb-2">Tasky</p>
        <p class="text-sm text-gray-400 leading-relaxed">
          Native desktop task management with CalDAV and GitHub sync.
        </p>
      </div>

      <!-- Documentation -->
      <div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Documentation</p>
        <ul class="space-y-2">
          {docLinks.map((link) => (
            <li>
              <a
                href={`${base}${link.slug}`}
                class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Project -->
      <div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Project</p>
        <ul class="space-y-2">
          <li>
            <a
              href="https://github.com/samclark2015/tasky"
              class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
            >
              GitHub
            </a>
          </li>
          <li>
            <a
              href="https://github.com/samclark2015/tasky/releases"
              class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
            >
              Releases
            </a>
          </li>
        </ul>
      </div>

    </div>

    <div class="border-t border-gray-100 pt-6 text-sm text-gray-400">
      &copy; {new Date().getFullYear()} Tasky &middot; Open source under MIT
    </div>
  </div>
</footer>
